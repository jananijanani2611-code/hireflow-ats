# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.3.2
# ----------------------------------------------------------------------------

if [ -z "$MAVEN_SKIP_RC" ] ; then
  if [ -f /usr/local/etc/mavenrc ] ; then
    . /usr/local/etc/mavenrc
  fi
  if [ -f /etc/mavenrc ] ; then
    . /etc/mavenrc
  fi
  if [ -f "$HOME/.mavenrc" ] ; then
    . "$HOME/.mavenrc"
  fi
fi

case "$(uname)" in CYGWIN*) CYGWIN=true;; MINGW*) MINGW=true;; esac

if [ -z "$JAVA_HOME" ]; then
  if [ -x /usr/libexec/java_home ]; then
    JAVA_HOME=$(/usr/libexec/java_home); export JAVA_HOME
  else
    JAVA_HOME=$(dirname $(dirname $(readlink -f $(which javac 2>/dev/null) 2>/dev/null) 2>/dev/null) 2>/dev/null)
  fi
fi

if [ -z "$JAVACMD" ] ; then
  if [ -n "$JAVA_HOME"  ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
      JAVACMD="$JAVA_HOME/jre/sh/java"
    else
      JAVACMD="$JAVA_HOME/bin/java"
    fi
  else
    JAVACMD="$(command -v java)"
  fi
fi

if [ ! -x "$JAVACMD" ] ; then
  echo "Error: JAVA_HOME is not defined correctly." >&2
  echo "  We cannot execute $JAVACMD" >&2
  exit 1
fi

if [ -z "$JAVA_HOME" ] ; then
  echo "Warning: JAVA_HOME environment variable is not set."
fi

BASE_DIR=$(dirname "$0")

# Provide a "standardized" way to retrieve the CLI args that will work with
# or without the presence of MAVEN_SKIP_RC
if [ -z "$MAVEN_SKIP_RC" ]; then
  MAVEN_CMD_LINE_ARGS="$MAVEN_CONFIG $@"
else
  MAVEN_CMD_LINE_ARGS="$@"
fi

WRAPPER_JAR="$BASE_DIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_LAUNCHER=org.apache.maven.wrapper.MavenWrapperMain

wrapperUrl=$(grep "^wrapperUrl" "$BASE_DIR/.mvn/wrapper/maven-wrapper.properties" | cut -d'=' -f2-)

if [ ! -f "$WRAPPER_JAR" ]; then
  echo "Downloading Maven Wrapper jar from: $wrapperUrl"
  if command -v curl >/dev/null 2>&1; then
    curl -o "$WRAPPER_JAR" "$wrapperUrl" -f -L
  elif command -v wget >/dev/null 2>&1; then
    wget "$wrapperUrl" -O "$WRAPPER_JAR"
  else
    echo "Error: curl or wget is required to download the Maven Wrapper jar." >&2
    exit 1
  fi
fi

exec "$JAVACMD" \
  $MAVEN_OPTS \
  $MAVEN_DEBUG_OPTS \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=${BASE_DIR}" \
  ${WRAPPER_LAUNCHER} $MAVEN_CMD_LINE_ARGS
